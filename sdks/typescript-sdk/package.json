{
  "name": "@terminal49/sdk",
  "version": "0.3.0",
  "description": "Terminal49 TypeScript SDK (JSON:API, openapi-fetch)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Terminal49/API.git",
    "directory": "sdks/typescript-sdk"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "generate:types": "openapi-typescript ../../docs/openapi.json -o src/generated/terminal49.ts",
    "docs": "npm run docs:clean && typedoc --options typedoc.json && node scripts/postprocess-generated-docs.mjs",
    "docs:clean": "node scripts/clean-generated-docs.mjs",
    "docs:mintlify": "npm run docs",
    "example": "node -r dotenv/config dist/scripts/example.js",
    "fixtures:generate": "node -r dotenv/config scripts/generate-fixtures.mjs",
    "smoke": "node -r dotenv/config dist/scripts/smoke.js",
    "smoke:lists": "node -r dotenv/config dist/scripts/list-smoke.js",
    "prepublishOnly": "npm run build",
    "lint": "oxlint src && oxfmt --check src",
    "format": "oxfmt --write src"
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jsona": "^1.14.0",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "dotenv": "^17.4.2",
    "openapi-typescript": "^7.13.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "minimatch": {
      "brace-expansion": "5.0.6"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.6"
    },
    "typedoc": {
      "minimatch": {
        "brace-expansion": "5.0.6"
      }
    },
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "rollup": "^4.60.4",
    "vite": "^7.3.3"
  }
}
