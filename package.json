{
  "name": "terminal49-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Terminal49 API with MCP Server",
  "workspaces": [
    "packages/*",
    "sdks/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "sdk:docs": "npm run docs --workspace @terminal49/sdk"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "mintlify": "^4.2.585",
    "openapi-fetch": "^0.15.2",
    "openapi-typescript": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "dotenv": "^17.3.1"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "axios": "^1.16.0",
    "brace-expansion": "5.0.6",
    "fast-uri": "^3.1.2",
    "uuid": "^11.1.1",
    "js-yaml": "^4.2.0",
    "lodash": "^4.18.1",
    "minimatch": {
      "brace-expansion": "5.0.6"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.6"
    },
    "typedoc": {
      "minimatch": {
        "brace-expansion": "5.0.6"
      }
    },
    "@terminal49/sdk": {
      "typedoc": {
        "minimatch": {
          "brace-expansion": "5.0.6"
        }
      }
    },
    "hono": "^4.12.25",
    "ip-address": "^10.1.1",
    "@mintlify/scraping": {
      "zod": "3.25.76"
    },
    "@mintlify/validation": {
      "zod": "3.25.76"
    },
    "@mintlify/previewing": {
      "express": "4.22.2"
    },
    "express-rate-limit": "^8.5.2",
    "rollup": "^4.60.4",
    "chromium-bidi": {
      "zod": "3.23.8"
    },
    "vite": "^8.0.16",
    "esbuild": "0.28.1",
    "form-data": "^4.0.6",
    "ws": "^8.21.0",
    "tar": "^7.5.16",
    "markdown-it": "^14.2.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
