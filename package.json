{
  "name": "terminal49-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Terminal49 API with MCP Server",
  "workspaces": [
    "packages/*",
    "sdks/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "sdk:docs": "npm run docs --workspace @terminal49/sdk"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "mintlify": "^4.2.359",
    "openapi-fetch": "^0.15.2",
    "openapi-typescript": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "dotenv": "^17.3.1"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "axios": "^1.16.0",
    "uuid": "^11.1.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "hono": "^4.12.16",
    "ip-address": "^10.1.1",
    "@mintlify/scraping": {
      "zod": "^3.24.0"
    },
    "chromium-bidi": {
      "zod": "3.23.8"
    }
  }
}
