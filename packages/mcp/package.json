{
  "name": "@terminal49/mcp",
  "version": "0.1.0",
  "description": "Terminal49 MCP Server for Vercel - TypeScript implementation",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint": "oxlint src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "type-check": "tsc --noEmit",
    "mcp:stdio": "tsx src/index.ts",
    "sdk:setup": "node ./scripts/sdk-setup.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "terminal49",
    "container-tracking",
    "vercel"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.55.0",
    "@terminal49/sdk": "0.3.0",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "ajv": "^8.20.0",
    "express-rate-limit": "^8.5.2",
    "fast-uri": "^3.1.2",
    "postcss": "^8.5.14",
    "hono": "^4.12.16",
    "ip-address": "^10.1.1",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "qs": "^6.15.2",
    "rollup": "^4.60.4",
    "vite": "^7.3.5"
  },
  "engines": {
    "node": "24.x"
  }
}
